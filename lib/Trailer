library figuras_flame;

import 'dart:ui';
import 'package:flame/components.dart';
import 'dart:ui';
import 'package:flame/game.dart';

class TrailerGame extends FlameGame {
  @override
  void render(Canvas canvas) {
    super.render(canvas);

    // Dibuje aquí su figura de trailer utilizando el objeto Canvas
    final trailerPaint = Paint()..color = const Color(0xFF0000FF);

    canvas.drawRect(
      Rect.fromLTWH(100, 100, 300, 150),
      trailerPaint,
    );

    final wheelPaint = Paint()..color = const Color(0xFF000000);

    canvas.drawCircle(
      Offset(130, 250),
      25,
      wheelPaint,
    );

    canvas.drawCircle(
      Offset(370, 250),
      25,
      wheelPaint,
    );
  }

  
}